{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Pinecall",
  "description": "Build real-time voice & messaging AI agents in TypeScript.",
  "colors": {
    "primary": "#0EA66B",
    "light": "#34D399",
    "dark": "#047857"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "groups": [
      {
        "group": "Get Started",
        "pages": [
          "index",
          "quickstart"
        ]
      },
      {
        "group": "Concepts",
        "pages": [
          "concepts/philosophy",
          "concepts/agents-and-channels",
          "concepts/server-vs-client-llm",
          "concepts/hot-reload",
          "concepts/deployment-topologies"
        ]
      },
      {
        "group": "Guides",
        "pages": [
          "guides/inbound-voice",
          "guides/outbound-calls",
          "guides/whatsapp",
          "guides/webrtc-browser",
          "guides/tools-and-functions",
          "guides/multi-tenant",
          "guides/sse-streaming",
          "guides/dev-mode",
          "guides/call-ringing"
        ]
      },
      {
        "group": "Examples",
        "pages": [
          "examples/headless-agent",
          "examples/multi-channel-bot",
          "examples/chat-bot",
          "examples/browser-widget"
        ]
      },
      {
        "group": "@pinecall/sdk (Node.js)",
        "pages": [
          "api/pinecall",
          "api/agent",
          "api/call",
          "api/reply-stream"
        ]
      },
      {
        "group": "@pinecall/voice-core (Browser)",
        "pages": [
          "voice-core/overview",
          "voice-core/voice-session",
          "voice-core/state-and-phases",
          "voice-core/datachannel-protocol"
        ]
      },
      {
        "group": "@pinecall/voice-widget (React)",
        "pages": [
          "voice-widget/overview",
          "voice-widget/props",
          "voice-widget/theming",
          "voice-widget/use-voice-session-hook",
          "voice-widget/tools-api"
        ]
      },
      {
        "group": "@pinecall/chat-core (Browser)",
        "pages": [
          "chat-core/overview",
          "chat-core/chat-session"
        ]
      },
      {
        "group": "Reference",
        "pages": [
          "reference/cli",
          "reference/events",
          "reference/stt-providers",
          "reference/tts-providers",
          "reference/llm-providers",
          "reference/session-limits",
          "reference/rest-api"
        ]
      },
      {
        "group": "Security",
        "pages": [
          "security"
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/pinecall"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Sign up",
      "href": "https://pinecall.io/signup"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/pinecall",
      "x": "https://x.com/pinecall"
    }
  },
  "search": {
    "prompt": "Search the Pinecall docs..."
  },
  "fonts": {
    "heading": {
      "family": "Geist"
    },
    "body": {
      "family": "Geist"
    }
  }
}
