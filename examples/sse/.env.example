# Pinecall API key (required)
PINECALL_API_KEY=pk_...

# Phone number to register (E.164 format)
PHONE=+13049709763

# Agent name (shows in the dashboard header)
AGENT_NAME=support

# STT model: "flux" (native turns, fastest) or "nova" (SmartTurn + broader language support)
MODEL=flux

# Language code: en, es, ar, fr, de, pt
STT_LANG=en

# System prompt for the agent
PROMPT="You are a friendly support assistant. Keep responses to 1-2 sentences since this is a voice call. Respond in the same language the user speaks."

# Dashboard port
PORT=4600
